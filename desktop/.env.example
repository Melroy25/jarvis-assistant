# JARVIS Desktop Client — Environment Variables
# Copy this to .env and fill in your values

# URL of your deployed backend (or http://localhost:3000 for local dev)
BACKEND_URL=https://your-jarvis-backend.vercel.app

# Shared secret token — must match JARVIS_API_TOKEN in backend .env
JARVIS_API_TOKEN=change-this-to-a-random-secret

# Picovoice Porcupine access key — get from https://picovoice.ai (free tier)
PICOVOICE_ACCESS_KEY=

# Path to downloaded Vosk model directory (default: ./vosk-model)
# Download from: https://alphacephei.com/vosk/models
# Recommended: vosk-model-small-en-us-0.15 (40MB) or vosk-model-en-us-0.22 (1.8GB)
VOSK_MODEL_PATH=./vosk-model

# Unique identifier for this device (optional, auto-generated otherwise)
DEVICE_ID=desktop-1

# Seconds to listen for a command after wake word (default: 5)
COMMAND_LISTEN_SECONDS=5

# TTS settings
TTS_RATE=180
TTS_VOLUME=1.0
