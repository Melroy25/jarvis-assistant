<?xml version="1.0" encoding="utf-8"?>
<!--
  JARVIS Main UI — Cinematic Anime Style
  Dark space background with animated orb, fog overlay, and waveform
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_space"
    tools:context=".MainActivity">

    <!-- Deep space star field background (static drawable) -->
    <ImageView
        android:id="@+id/starBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_stars"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dark overlay — animates to 0.65 alpha on activation -->
    <View
        android:id="@+id/darkOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Lottie fog/particle animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/fogAnimation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:lottie_rawRes="@raw/fog_animation"
        app:lottie_loop="true"
        app:lottie_autoPlay="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Top status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.15"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp" />

    <!-- Central orb container — tap to activate -->
    <FrameLayout
        android:id="@+id/orbContainer"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer glow ring (animated scale on activation) -->
        <ImageView
            android:id="@+id/orbRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/orb_ring"
            android:scaleType="fitCenter" />

        <!-- Waveform view inside the orb -->
        <com.jarvis.assistant.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="invisible" />

        <!-- JARVIS text label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="JARVIS"
            android:textColor="#DDFFFFFF"
            android:textSize="20sp"
            android:letterSpacing="0.4"
            android:fontFamily="sans-serif-thin" />

    </FrameLayout>

    <!-- Bottom hint text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text='Say "Jarvis" or tap to activate'
        android:textColor="#55FFFFFF"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
